  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../.tmp",
    "baseUrl": ".."
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
